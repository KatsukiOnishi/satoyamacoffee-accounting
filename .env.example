# freee API
# FREEE_API_KEY は後方互換用（accounting auth init 後は secrets/freee_tokens.json が優先）
FREEE_API_KEY=
FREEE_COMPANY_ID=

# freee OAuth（access_token 自動更新で必須）
# Client ID はプライベートアプリ画面で確認、Client Secret はチャットに貼らないこと
FREEE_CLIENT_ID=724895154046051
FREEE_CLIENT_SECRET=__FREEE_CLIENT_SECRET__
# トークン保管ファイル（accounting auth init で初回作成。gitignore 配下に置く）
FREEE_TOKEN_FILE=./secrets/freee_tokens.json

# freee 勘定科目ID（freee画面 > 設定 > 勘定科目 で確認できる整数値を入れる）
# 商品（棚卸資産）
FREEE_ACCOUNT_ITEM_INVENTORY=
# 期首商品棚卸高
FREEE_ACCOUNT_ITEM_OPENING_INVENTORY=
# 売上高
FREEE_ACCOUNT_ITEM_SALES=
# 売掛金
FREEE_ACCOUNT_ITEM_RECEIVABLE=
# 支払手数料
FREEE_ACCOUNT_ITEM_COMMISSION=

# freee 税区分（要確認: freeeの実際のコードに合わせる）
# 課税売上10%（仮値: 21）
FREEE_TAX_CODE_SALES=
# 不課税（支払手数料、仮値: 0）
FREEE_TAX_CODE_FEE=

# Anthropic Claude Vision API
ANTHROPIC_API_KEY=

# Gmail OAuth（vendor-invoice タスクで使用）
# Google Cloud Console で「デスクトップアプリ」OAuth クライアントIDを作成して
# ダウンロードした client_secret_xxx.json を gmail_credentials.json として配置する。
# 初回 `accounting auth gmail-init` 実行時にブラウザでGoogle認可 → tokens.json 生成。
GMAIL_CREDENTIALS_FILE=./secrets/gmail_credentials.json
GMAIL_TOKEN_FILE=./secrets/gmail_tokens.json
GMAIL_USER_ID=me
VENDOR_INVOICE_ATTACHMENTS_DIR=/tmp/vendor_invoice_attachments

# 百貨店取引先マッピング（vendor slug → freee partner_id）
# 形式: VENDOR_MAP_{SLUG}={freee_partner_id},{partner_display_name}
# 注意: 値の中に「#」を含めない（インラインコメント不可、コメントは必ず別行に書く）
VENDOR_MAP_SEIBU=__SEIBU_PARTNER_ID__,株式会社そごう・西武
# 将来追加例:
# VENDOR_MAP_MARUI=__MARUI_PARTNER_ID__,株式会社丸井

# 他システム連携（後続実装で利用）
COFFEE_SYSTEM_BASE_URL=https://satoyamacoffee-inventory-system.onrender.com
COFFEE_SYSTEM_API_KEY=
ATTENDANCE_SYSTEM_BASE_URL=https://shifts.satoyamacoffee.com
# 読み取り（GET /api/external/salary）。attendance-system 側 EXTERNAL_API_KEY と同値
ATTENDANCE_SYSTEM_API_KEY=
SHOPIFY_SHOP_DOMAIN=satoyama-coffee.myshopify.com
# 正規キー（仕様書 §4-1）。後方互換のため SHOPIFY_ACCESS_TOKEN も同値があれば fallback。
SHOPIFY_ADMIN_API_TOKEN=__SHOPIFY_ADMIN_API_TOKEN__
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2026-01

# shopify-sales タスク（月次 EC 売上 → freee 振替伝票）
# KOMOJU 手数料率（API では fees=[] のため固定率で算出）
SHOPIFY_KOMOJU_FEE_RATE=0.036
# gateway → freee partner マッピング。形式: <partner_id>,<display_name>
# 未設定だと shopify-sales 実行時に PartnerNotConfiguredError。
# - shopify_payments: 新規 partner『Shopify Payments』を freee 画面で作成して ID を入れる
# - KOMOJU: 102026938 が正規（全角閉じ括弧）。available=False の場合は freee 画面で再有効化
SHOPIFY_SALES_PARTNER_SHOPIFY_PAYMENTS=__SHOPIFY_PAYMENTS_PARTNER_ID__,Shopify Payments
SHOPIFY_SALES_PARTNER_KOMOJU=102026938,株式会社デジカ（KOMOJU）
SHOPIFY_SALES_PARTNER_AMAZON_PAY=84382680,Amazon Pay
SHOPIFY_SALES_PARTNER_PAYPAY=80584926,PayPay
# 勘定科目 ID（未指定なら freee API から「売掛金 / 売上高 / 支払手数料」を name で引く）
# 既知値: SHOPIFY_SALES_ACCOUNT_RECEIVABLE_ID=512405349 / SALES_ID=512405441 / COMMISSION_ID=512405479
SHOPIFY_SALES_ACCOUNT_RECEIVABLE_ID=
SHOPIFY_SALES_ACCOUNT_SALES_ID=
SHOPIFY_SALES_ACCOUNT_COMMISSION_ID=
# 税区分コード（既定: 156=軽減税率8%売上、2=対象外、0=なし）
SHOPIFY_SALES_TAX_CODE_SALES_REDUCED_8=156
SHOPIFY_SALES_TAX_CODE_OUT_OF_SCOPE=2
SHOPIFY_SALES_TAX_CODE_NONE=0

# HRMOS（勤怠 CSV 取得元）— sync-hrmos タスクで使用
HRMOS_LOGIN_URL=https://f.ieyasu.co/asd2171/login
HRMOS_USER=__SET_ME__
HRMOS_PASS=__SET_ME__
# 対象外にする HRMOS 社員ID（テストアカウント / 退職者など、カンマ区切り）
# 空でも可。例: HRMOS_EXCLUDE_USER_IDS=5,6
HRMOS_EXCLUDE_USER_IDS=

# shifts への書き込み（POST /api/admin/import-hrmos）— attendance-system 側 ADMIN_API_KEY と同値
SHIFTS_BASE_URL=https://shifts.satoyamacoffee.com
SHIFTS_ADMIN_API_KEY=__SET_ME__

# メール通知（Resend）
RESEND_API_KEY=
NOTIFY_EMAIL=katsuki.onishi@gmail.com
FROM_EMAIL=noreply@satoyamacoffee.com
NOTIFY_ON_SUCCESS=false

# 実行モード
DRY_RUN=true
LOG_LEVEL=INFO
DATABASE_PATH=./accounting.db

# Web UI
WEB_HOST=0.0.0.0
WEB_PORT=8080
# 固定トークン。空ならサーバ起動毎にランダム生成。
# 固定すると http://localhost:8080/?token=<value> をブックマークして再利用可能。
# 生成: openssl rand -hex 32
ACCOUNTING_WEB_TOKEN=
